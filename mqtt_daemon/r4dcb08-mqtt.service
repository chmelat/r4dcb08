[Unit]
Description=R4DCB08 Temperature Sensor MQTT Publisher
After=network-online.target mosquitto.service dev-ttyUSB0.device
Wants=network-online.target mosquitto.service
BindsTo=dev-ttyUSB0.device
StartLimitIntervalSec=0
ConditionPathExists=/etc/r4dcb08-mqtt.conf

[Service]
Type=notify
NotifyAccess=main
ExecStart=/usr/local/bin/r4dcb08-mqtt -c /etc/r4dcb08-mqtt.conf
ExecReload=/bin/kill -HUP $MAINPID
TimeoutStartSec=120
TimeoutStopSec=10
WatchdogSec=3600
Restart=on-failure
RestartSec=30

# Run as root (required for serial port access)
User=root
Group=root

[Install]
WantedBy=multi-user.target
